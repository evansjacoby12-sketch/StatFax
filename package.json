  "scripts": {
    "test": "node --test test/*.test.mjs",
    "serve": "node server/serve.mjs",
    "build-model": "node server/build-model.mjs",
    "slate": "node server/fetch-slate.mjs",
    "context": "node server/context-pass.mjs",
