    "lab:backtest": "node model-lab/backtest.mjs",
    "lab:train": "node model-lab/train-logreg.mjs",
    "lab:score": "node model-lab/score-offline.mjs",
    "lab:audit": "node model-lab/badge-audit.mjs",
    "lab:blast": "node model-lab/blast-audit.mjs",
    "lab:blast-model": "node model-lab/blast-model.mjs",
    "lab:board": "node model-lab/board-evolution.mjs",
