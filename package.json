{
  "name": "statfax-brain",
  "private": true,
  "type": "module",
  "description": "StatFax MLB home-run probability engine + data pipeline — the headless 'brain' behind statfax.online.",
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "serve": "node server/serve.mjs",
    "build-model": "node server/build-model.mjs",
    "slate": "node server/fetch-slate.mjs",
    "validate:mlb-data": "node server/tools/validate-mlb-data.mjs",
    "mlb:data-health": "node server/mlb-data-health.mjs",
    "validate:mlb-data-health": "node server/tools/validate-mlb-data-health.mjs",
    "validate:ai-context": "node server/tools/validate-ai-context.mjs",
    "validate:ai-shadow": "node server/tools/validate-ai-shadow.mjs",
    "validate:ai-production": "node server/tools/validate-ai-production.mjs",
    "validate:ai-evaluation": "node server/tools/validate-ai-evaluation.mjs",
    "validate:ai-history": "node server/tools/validate-ai-history.mjs",
    "context": "node server/context-pass.mjs",
    "ai:hr-shadow": "node server/ai-hr-shadow.mjs",
    "ai:hr-production": "node server/ai-hr-production.mjs",
    "ai:hr-evaluate": "node server/ai-hr-evaluate.mjs",
    "ai:hr-history": "node server/ai-hr-history.mjs",
    "brief": "node server/slate-brief.mjs",
    "reconcile": "node server/reconcile.mjs",
    "nfl:history": "python server/sports/nfl/build-history.py --from-season 2020",
    "nfl:history:quick": "python server/sports/nfl/build-history.py --from-season 2020 --skip-pbp",
    "nfl:slate": "node server/sports/nfl/fetch-nfl-slate.mjs",
    "nfl:backtest": "node server/sports/nfl/backtest.mjs",
    "lab:pull": "node model-lab/pull-data.mjs",
    "lab:backtest": "node model-lab/backtest.mjs",
    "lab:train": "node model-lab/train-logreg.mjs",
    "lab:score": "node model-lab/score-offline.mjs",
    "lab:audit": "node model-lab/badge-audit.mjs",
    "lab:blast": "node model-lab/blast-audit.mjs",
    "lab:blast-model": "node model-lab/blast-model.mjs",
    "lab:board": "node model-lab/board-evolution.mjs",
    "lab:k": "node model-lab/k-prop-audit.mjs",
    "lab:matchup": "node model-lab/matchup-model.mjs",
    "lab:validate-ceil": "node model-lab/validate-ceil.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
